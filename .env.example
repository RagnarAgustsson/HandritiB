# ─── AI Provider ────────────────────────────────────────────────────────────
# Veldu módel fyrir yfirferð og samantekt: "openai" eða "gemini"
# Transcription er alltaf OpenAI (gpt-4o-transcribe / whisper-1)
AI_PROVIDER=openai

# ─── OpenAI ─────────────────────────────────────────────────────────────────
# Fáðu lykil á: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ─── Gemini (valkvæmt — aðeins ef AI_PROVIDER=gemini) ──────────────────────
# Fáðu lykil á: https://aistudio.google.com/apikey
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.5-pro

# ─── Clerk (Auth) ────────────────────────────────────────────────────────────
# 1. Búðu til reikning á: https://clerk.com
# 2. Búðu til nýja umsókn (application)
# 3. Farðu í API Keys - afritaðu báða lykla
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk slóðir (breyta ekki)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/innskraning
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/nýskráning
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ─── Neon (Gagnagrunnur) ─────────────────────────────────────────────────────
# 1. Búðu til reikning á: https://neon.tech
# 2. Búðu til nýtt verkefni
# 3. Afritaðu 'Connection string' úr Neon Dashboard
DATABASE_URL=postgresql://...

# ─── Vercel (Vefgisting) ─────────────────────────────────────────────────────
# Stillingar eru settar beint í Vercel Dashboard
# Engar sérstakar breytur þarf hér
